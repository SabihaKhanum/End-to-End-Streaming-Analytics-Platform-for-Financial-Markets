# ─────────────────────────────────────────────
# Oil Pipeline Environment Configuration
# Copy to .env and edit for your environment
# ─────────────────────────────────────────────

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_REPLICATION_FACTOR=1

# Schema Registry
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# TimescaleDB
TIMESCALE_DSN=postgresql://oiluser:oilpass@timescaledb:5432/oildb
POSTGRES_USER=oiluser
POSTGRES_PASSWORD=oilpass
POSTGRES_DB=oildb

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000

# Producer settings
TICK_INTERVAL_MS=500        # tick every 500ms per benchmark

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Superset
SUPERSET_SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Alert thresholds (overrides processor.py defaults)
SPIKE_PCT_THRESHOLD=0.5
SPREAD_WIDE_THRESHOLD=5.0

# ── Production real data sources (leave blank to use simulator) ──
# CME_API_KEY=
# ICE_API_KEY=
# REFINITIV_API_KEY=
# EIA_API_KEY=
